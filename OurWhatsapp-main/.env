# Production Environment Configuration
# Generated secure secrets for production deployment

# Database Configuration
MONGODB_URI=mongodb://admin:password123@mongodb:27017/whatsapp-clone?authSource=admin
REDIS_URL=redis://:redis123@redis:6379

# JWT Configuration - SECURE RANDOM SECRETS GENERATED
JWT_SECRET=7K9mP4vR8nL2qX5wF3hJ6kZ9sN8bR2mP4vR8nL2qX5wF3hJ
JWT_REFRESH_SECRET=9Q8nL3xR7mP2vK5wF3hJ9kZ7sN8bR2mP4vR8nL2qX5wF3hJ
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Encryption Configuration - SECURE RANDOM KEY GENERATED
ENCRYPTION_KEY=a8B4k9mP3vR6nL2qX5wF3hJ7kZ9sN8bR2mP4vR8nL2qX5wF3hJ

# SMS Configuration - TWILIO
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Server Configuration
PORT=3000
NODE_ENV=production

# Security Headers
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Monitoring
LOG_LEVEL=info
ENABLE_METRICS=true

# Docker Configuration
COMPOSE_PROJECT_NAME=whatsapp-prod
COMPOSE_FILE=production-docker-compose.yml

# SSL Configuration (update with your domain)
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.com.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.com.key

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Monitoring Configuration
HEALTH_CHECK_INTERVAL=30s
METRICS_ENDPOINT=https://metrics.yourdomain.com
